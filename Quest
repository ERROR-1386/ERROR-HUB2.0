-- Поиск папки с квестами в игре Build a Boat
local replicatedStorage = game:GetService("ReplicatedStorage")
local remoteEvents = replicatedStorage:FindFirstChild("RemoteEvents")

-- Функция безопасной отправки запроса серверу на запуск квеста
local function activateQuest(questName)
    -- Пробуем стандартный путь для квестов в Build a Boat
    local questEvent = replicatedStorage:FindFirstChild("SelectQuest") or replicatedStorage:FindFirstChild("SetQuest")
    
    if remoteEvents and remoteEvents:FindFirstChild("SelectQuest") then
        questEvent = remoteEvents.SelectQuest
    elseif remoteEvents and remoteEvents:FindFirstChild("SetQuest") then
        questEvent = remoteEvents.SetQuest
    end

    if questEvent and questEvent:IsA("RemoteEvent") then
        questEvent:FireServer(questName)
    else
        -- Альтернативный поиск по всему ReplicatedStorage, если разработчики сменили путь
        local found = false
        for _, obj in ipairs(replicatedStorage:GetDescendants()) do
            if obj:IsA("RemoteEvent") and (obj.Name == "SelectQuest" or obj.Name == "SetQuest" or obj.Name == "ActivateQuest") then
                obj:FireServer(questName)
                found = true
                break
            end
        end
        if not found then
            warn("Ошибка: Не удалось найти RemoteEvent для активации квестов.")
        end
    end
end

